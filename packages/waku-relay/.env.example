# --- required ---
# A node that exposes the msgboard_ JSON-RPC module (public PulseChain RPCs do NOT).
MSGBOARD_RPC_URL=https://one.valve.city/rpc/vk_demo/evm/369
# Comma-separated channel / Waku topic names to relay.
RELAY_CHANNELS=lobby,games

# --- optional ---
# Informational chain id (369 PulseChain, 943 testnet, 1 mainnet).
MSGBOARD_CHAIN_ID=369
# Waku app name → content topic /{appName}/1/{channel}/proto
WAKU_APP_NAME=msgboard-relay
# Comma-separated Waku bootstrap multiaddrs; leave empty for defaultBootstrap.
WAKU_BOOTSTRAP=
# Channel→category hashing: keccak256 (default, @msgboard/sdk + games) or ascii32 (@msgboard/relayer).
RELAY_CATEGORY_ENCODING=keccak256
# Post the origin-tagged envelope (default) or the raw Waku payload: envelope | raw
RELAY_BODY_MODE=envelope
# Persistent dedup append-log (survives restarts so messages aren't re-stamped/re-posted).
RELAY_SEEN_PATH=./.waku-relay-seen.log
# Set to 1 to log what WOULD be posted without spending PoW.
RELAY_DRY_RUN=0
# Optional board difficulty overrides (else SDK defaults / board-supplied values).
# MSGBOARD_WORK_MULTIPLIER=10000
# MSGBOARD_WORK_DIVISOR=1000000
