# Waku box (.env). Copy to .env on 88.99.62.98 and fill in. NEVER commit the real .env.

# The public subdomain for the WSS endpoint. DNS A record -> this box (88.99.62.98), DNS-only
# (grey cloud / NOT Cloudflare-proxied) so Caddy can complete the Let's Encrypt ACME challenge.
WAKU_DOMAIN=waku.msgboard.xyz
ACME_EMAIL=dev@valve.city

# nwaku node key — a 32-byte hex. Generate ONCE and keep it stable so the peer id (and thus the
# multiaddr friends dial) never changes:   openssl rand -hex 32
WAKU_NODEKEY=REPLACE_WITH_openssl_rand_hex_32

# --- relay profile only (docker compose --profile relay up -d) ---
# MsgBoard node exposing the msgboard_ module (valve.city). 943 = PulseChain v4 testnet (free PoW).
MSGBOARD_RPC_URL=https://one.valve.city/rpc/vk_demo/evm/943
# Comma-separated channel / content-topic names to mirror to the board.
RELAY_CHANNELS=lobby
WAKU_APP_NAME=msgboard-relay
RELAY_CATEGORY_ENCODING=keccak256
# Set AFTER nwaku's first start, once you know its peer id (see README step 5):
#   /dns4/nwaku/tcp/8001/ws/p2p/<PEER_ID>     (internal compose-network dial; plain ws)
WAKU_BOOTSTRAP=
