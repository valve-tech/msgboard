# Caddy on the waku box — terminates TLS with the Cloudflare *.msgboard.xyz ORIGIN cert (same model as
# the msgboard box; NO Let's Encrypt) and reverse-proxies the WebSocket upgrade to nwaku's plain-ws port.
#
# The record stays PROXIED through Cloudflare (orange cloud), so the box's real IP is never in public
# DNS. Cloudflare presents its own browser-trusted edge cert to friends and connects to this origin over
# the origin cert (use Cloudflare SSL mode "Full (strict)"). Cloudflare proxies WebSockets by default.
# Lock the box down further by firewalling :443 to Cloudflare's IP ranges only.
{$WAKU_DOMAIN} {
	encode gzip
	tls /etc/caddy/origin.pem /etc/caddy/origin.key
	# Caddy upgrades the WebSocket transparently; js-waku dials wss://{$WAKU_DOMAIN} (tcp/443/wss).
	reverse_proxy nwaku:8001
}
