{
  "name": "@msgboard/relayer",
  "version": "0.0.30",
  "description": "Controllable, safe-by-default pool-watcher relayer for the msgboard board",
  "repository": "github:valve-tech/msgboard",
  "author": "MsgBoard",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "keywords": ["msgboard", "relayer", "pool-watcher", "pulsechain"],
  "scripts": {
    "prebuild": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc",
    "watch": "tsc -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "prettier --check ."
  },
  "files": ["dist/"],
  "dependencies": {
    "@msgboard/history": "^0.0.30",
    "@msgboard/sdk": "^0.0.30",
    "viem": "^2.25.0"
  },
  "peerDependencies": {
    "pg": "^8.14.1"
  },
  "peerDependenciesMeta": {
    "pg": { "optional": true }
  },
  "devDependencies": {
    "@types/pg": "^8.11.11",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
