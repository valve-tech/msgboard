{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["./scripts", "./test", "./ignition", "hardhat.config.ts"],
  // Hardhat's mocha runner require()s the sibling games packages' TS SOURCE (their `main` points
  // at src/index.ts). Those packages are type:module, which node's CJS loader refuses — but
  // ts-node compiled them as CJS in the pre-extraction repo (no tsconfig anywhere), and the
  // sources are written to survive that (see msgboard-games stamper.ts dual-mode loader).
  // moduleTypes reproduces that classification for the hardhat test runner only.
  "ts-node": {
    "moduleTypes": {
      "../*/src/**/*": "cjs",
      "../*/index.js": "cjs"
    }
  }
}
