{
  "name": "@msgboard/pow-grinder",
  "version": "0.1.0",
  "description": "Fast native/WASM MsgBoard proof-of-work stamper (bit-identical to the reth node verifier)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gibs-finance/random.git",
    "directory": "examples/games/pow-grinder"
  },
  "main": "index.js",
  "module": "pkg/pow_grinder.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./wasm": {
      "types": "./pkg/pow_grinder.d.ts",
      "default": "./pkg/pow_grinder.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "pkg",
    "PUBLISHING.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:native": "cargo build --release --features napi && bash scripts/copy-native.sh",
    "build:wasm": "wasm-pack build --release --target web --out-dir pkg -- --no-default-features --features wasm",
    "prepublishOnly": "npm run build:wasm",
    "test": "cargo test --release"
  }
}
